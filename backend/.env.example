# Copy to backend/.env for local development only.
# Never commit backend/.env — it is gitignored.
# On production servers, inject secrets via the host (systemd, Docker, Azure, etc.)
# instead of keeping a plaintext file on disk.

NODE_ENV=development
PORT=5026

# Database
MONGO_URI=mongodb://localhost:27017/tender360

# Auth — use long random strings (min 32 chars) in any shared environment
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# CORS / frontend
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# AI providers (optional — features fail closed when unset)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_PROVIDER=gemini

# Email — SMTP for outbound mail
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Email — IMAP for tender inbox scanning (optional)
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=
EMAIL_APP_PASSWORD=

# Microsoft Graph (optional)
# MS_GRAPH_TENANT_ID=
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=

# External connectors (optional)
# GOVWIN_API_KEY=
# GOVWIN_BASE_URL=
# SAM_GOV_API_KEY=
# SALESFORCE_INSTANCE_URL=
# SALESFORCE_ACCESS_TOKEN=

# Discovery — import curated DEMO-* tenders only when source demoMode is on AND one of:
# DISCOVERY_DEMO_FALLBACK=true  OR  NODE_ENV=development
# DISCOVERY_DEMO_FALLBACK=false

# Misc
# SERVE_STATIC=true
# SEED_DB=false
# BOT_FAILURE_NOTIFY_EMAILS=admin@example.com

# Force reading backend/.env when NODE_ENV=production (local prod testing only)
# LOAD_DOTENV=true
