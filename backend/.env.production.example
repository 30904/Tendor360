# Copy to backend/.env on the production server (never commit real secrets)

NODE_ENV=production
PORT=5025

# Required — MongoDB Atlas or self-hosted (whitelist server IP)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/tender360?retryWrites=true&w=majority

# Required — use long random strings in production
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars

# Frontend origin (exact URL, no trailing slash)
CORS_ORIGIN=https://tender360.smart-aiapps.com

# Optional — serve frontend/dist from Node (if NOT using nginx for static files)
# SERVE_STATIC=true

# Optional integrations
# GOVWIN_API_KEY=
# GOVWIN_BASE_URL=
# SAM_GOV_API_KEY=
# MS_GRAPH_TENANT_ID=
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@smart-aiapps.com
# BOT_FAILURE_NOTIFY_EMAILS=admin@example.com
