## Proposed Changes

### Backend — New Data Model

#### [NEW] `backend/src/models/RfpResponse.js`

The core Mongoose schema for a supplier's RFP response project:

```javascript
{
  tenderId: ObjectId,           // Links to the approved Tender
  companyId: ObjectId,          // Multi-tenant isolation
  evaluationId: ObjectId,       // Links to the BID approval
  pricingId: ObjectId,          // Links to the pricing scenario

  metadata: {
    projectName: String,
    rfpNumber: String,
    submissionDeadline: Date,
    status: 'DRAFT' | 'IN_PROGRESS' | 'REVIEW' | 'APPROVED' | 'SUBMITTED',
    createdBy: ObjectId,
    approvedBy: ObjectId,
    approvedAt: Date
  },

  // Phase 1 output: Extracted requirements
  extractedRequirements: [{
    id: String,
    requirement: String,
    category: 'TECHNICAL' | 'COMMERCIAL' | 'COMPLIANCE' | 'TIMELINE',
    mandatory: Boolean,
    addressed: Boolean,        // Tracks if a section covers this
    addressedBySectionId: String
  }],

  // Phase 2 output: Generated proposal sections
  sections: [{
    id: String,
    title: String,
    type: 'EXECUTIVE_SUMMARY' | 'TECHNICAL_APPROACH' | 'METHODOLOGY' | 
          'TEAM_QUALIFICATIONS' | 'PAST_PERFORMANCE' | 'COMPLIANCE_MATRIX' | 
          'PRICING_SUMMARY' | 'RISK_MITIGATION' | 'CUSTOM',
    content: String,           // The actual proposal text (Markdown)
    status: 'PENDING' | 'GENERATING' | 'DRAFT' | 'NEEDS_REVIEW' | 
            'APPROVED' | 'MANUALLY_WRITTEN',
    
    // AI metadata
    aiMetadata: {
      model: String,           // e.g. "gemini-2.5-flash"
      promptVersion: String,   // Tracks which prompt template was used
      groundingSources: [String], // Content library IDs used as context
      schemaValid: Boolean,
      factCheckScore: Number,  // 0-100
      confidenceScore: Number, // 0-100 composite
      generatedAt: Date,
      retryCount: Number,
      rawTokensUsed: Number
    },

    // Human review
    reviewedBy: ObjectId,
    reviewedAt: Date,
    reviewComments: String,
    wordCount: Number,
    order: Number              // Display order in the final document
  }],

  // Phase 3 output: Compliance audit trail
  complianceAudit: {
    totalRequirements: Number,
    addressedCount: Number,
    coveragePercentage: Number,
    unaddressedRequirements: [String],
    auditedAt: Date
  }
}
```

